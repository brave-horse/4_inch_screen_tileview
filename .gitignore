# ====================================================
# 编译产物 & 构建输出
# ====================================================

# CMake / Ninja 构建输出目录
build/
b_lvgl/

# 各 board 下的编译中间文件 (obj/objs)
**/board/*/obj/
**/board/*/objs/

# CPU 端编译产物 (固件 / ELF / map / symbol / 中间文件)
cpu/*/tools/*.bin
cpu/*/tools/*.lz4
cpu/*/tools/*.fw
cpu/*/tools/*.ufw
cpu/*/tools/sdk.elf
cpu/*/tools/sdk.elf.*
cpu/*/tools/*.map
cpu/*/tools/symbol_tbl.txt
cpu/*/tools/dlog.bin

# 编译过程自动生成的 .used 备份 (带哈希后缀)
cpu/*/sdk_used_list.used-*

# 编译中间文件 (通用)
*.o
*.d

# ====================================================
# PC 模拟器项目 —— 不上传
# ====================================================
lv_port_pc_eclipse-release-v8.3/

# ====================================================
# 日志 & 临时文件
# ====================================================
build_log.txt
*.log

# ====================================================
# IDE / 编辑器
# ====================================================
.vscode/
.idea/
*.workspace
*~              # Vim/Gedit 备份
*.swp           # Vim 交换文件
*.swo
*.bak           # 通用备份

# ====================================================
# 操作系统杂项
# ====================================================
.DS_Store       # macOS
Thumbs.db       # Windows
desktop.ini     # Windows

# ====================================================
# Python
# ====================================================
__pycache__/
*.pyc
*.pyo

# ====================================================
# Git 内部 / 备份
# ====================================================
.git_old_backup/
.claude/

# generated 是 GUI-Guider 自动生成(符号链接→D盘),不进git(能重新生成)
/apps/demo/demo_ui/GUI_app/generated
